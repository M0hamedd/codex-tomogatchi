{
  "name": "codex-tomogatchi-overlay",
  "version": "0.1.0",
  "private": true,
  "description": "Always-on-top Electron overlay for the Codex Tomogatchi pet.",
  "author": "Codex Tomogatchi Contributors",
  "license": "MIT",
  "homepage": "https://github.com/M0hamedd/codex-tomogatchi#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/M0hamedd/codex-tomogatchi.git"
  },
  "bugs": {
    "url": "https://github.com/M0hamedd/codex-tomogatchi/issues"
  },
  "main": "overlay/main.js",
  "engines": {
    "node": ">=22",
    "npm": ">=10"
  },
  "scripts": {
    "start": "electron .",
    "overlay": "electron .",
    "package": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win",
    "setup": "node scripts/run_python.js plugins/codex-tomogatchi/scripts/tomogatchi.py settings --init && node scripts/run_python.js plugins/codex-tomogatchi/scripts/tomogatchi.py install && node scripts/run_python.js plugins/codex-tomogatchi/scripts/tomogatchi.py reset --confirm --from-now && node scripts/run_python.js plugins/codex-tomogatchi/scripts/tomogatchi.py doctor",
    "status": "node scripts/run_python.js plugins/codex-tomogatchi/scripts/tomogatchi.py status",
    "sync": "node scripts/run_python.js plugins/codex-tomogatchi/scripts/tomogatchi.py sync",
    "doctor": "node scripts/run_python.js plugins/codex-tomogatchi/scripts/tomogatchi.py doctor",
    "care": "node scripts/run_python.js plugins/codex-tomogatchi/scripts/tomogatchi.py care",
    "feed": "node scripts/run_python.js plugins/codex-tomogatchi/scripts/tomogatchi.py care feed",
    "rest": "node scripts/run_python.js plugins/codex-tomogatchi/scripts/tomogatchi.py care rest",
    "play": "node scripts/run_python.js plugins/codex-tomogatchi/scripts/tomogatchi.py care play",
    "comfort": "node scripts/run_python.js plugins/codex-tomogatchi/scripts/tomogatchi.py care comfort",
    "backup": "node scripts/run_python.js plugins/codex-tomogatchi/scripts/tomogatchi.py backup create",
    "test": "node scripts/run_python.js scripts/run_checks.py"
  },
  "build": {
    "appId": "dev.codex.tomogatchi",
    "productName": "Codex Tomogatchi",
    "directories": {
      "output": "dist"
    },
    "files": [
      "overlay/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "plugins/codex-tomogatchi",
        "to": "plugins/codex-tomogatchi",
        "filter": [
          "assets/**/*",
          "scripts/**/*",
          ".codex-plugin/**/*",
          "README.md"
        ]
      }
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis",
        "zip"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "electron": "^42.4.1",
    "electron-builder": "^26.8.1"
  }
}
