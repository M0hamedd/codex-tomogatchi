{
  "name": "codex-tomogatchi-overlay",
  "version": "0.1.0",
  "private": true,
  "description": "Always-on-top Electron overlay for the Codex Tomogatchi pet.",
  "author": "Codex Tomogatchi Contributors",
  "main": "overlay/main.js",
  "scripts": {
    "start": "electron .",
    "overlay": "electron .",
    "package": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win",
    "status": "python plugins/codex-tomogatchi/scripts/tomogatchi.py status",
    "sync": "python plugins/codex-tomogatchi/scripts/tomogatchi.py sync",
    "doctor": "python plugins/codex-tomogatchi/scripts/tomogatchi.py doctor",
    "backup": "python plugins/codex-tomogatchi/scripts/tomogatchi.py backup create",
    "test": "python scripts/run_checks.py"
  },
  "build": {
    "appId": "dev.codex.tomogatchi",
    "productName": "Codex Tomogatchi",
    "directories": {
      "output": "dist"
    },
    "files": [
      "overlay/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "plugins/codex-tomogatchi",
        "to": "plugins/codex-tomogatchi",
        "filter": [
          "assets/**/*",
          "scripts/**/*",
          ".codex-plugin/**/*",
          "README.md"
        ]
      }
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis",
        "zip"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "electron": "^42.3.2",
    "electron-builder": "^26.8.1"
  }
}
