{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"plugins/codex-tomogatchi/scripts/tomogatchi.py\" hook SessionStart",
            "commandWindows": "py -3 \"plugins/codex-tomogatchi/scripts/tomogatchi.py\" hook SessionStart",
            "timeout": 10,
            "statusMessage": "Updating Codex Tomogatchi"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"plugins/codex-tomogatchi/scripts/tomogatchi.py\" hook UserPromptSubmit",
            "commandWindows": "py -3 \"plugins/codex-tomogatchi/scripts/tomogatchi.py\" hook UserPromptSubmit",
            "timeout": 10,
            "statusMessage": "Updating Codex Tomogatchi"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"plugins/codex-tomogatchi/scripts/tomogatchi.py\" hook PostToolUse",
            "commandWindows": "py -3 \"plugins/codex-tomogatchi/scripts/tomogatchi.py\" hook PostToolUse",
            "timeout": 10,
            "statusMessage": "Updating Codex Tomogatchi"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"plugins/codex-tomogatchi/scripts/tomogatchi.py\" hook Stop",
            "commandWindows": "py -3 \"plugins/codex-tomogatchi/scripts/tomogatchi.py\" hook Stop",
            "timeout": 10,
            "statusMessage": "Updating Codex Tomogatchi"
          }
        ]
      }
    ]
  }
}
